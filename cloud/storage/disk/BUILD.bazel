load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "disk",
    srcs = ["disk.go"],
    importpath = "upspin.io/cloud/storage/disk",
    visibility = ["//visibility:public"],
    deps = [
        "//cloud/storage",
        "//cloud/storage/disk/internal/local",
        "//errors",
        "//upspin",
    ],
)

go_test(
    name = "disk_test",
    srcs = ["disk_test.go"],
    embed = [":disk"],
    deps = [
        "//cloud/storage",
        "//upspin",
    ],
)
