    name = "rpc_test",
    srcs = ["all_test.go"],
    data = [
        "//key/testdata",
        "//rpc/testdata:rpc_testdata",
    ],
    embed = [":rpc"],
    deps = [
        "//cache",
        "//cloud/https",
        "//config",
        "//errors",
        "//factotum",
        "//log",
        "//rpc/testdata",
        "//test/testutil",
        "//upspin",
        "@com_github_golang_protobuf//proto",
    ],
