load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "rpc",
    srcs = [
        "certpool.go",
        "client.go",
        "doc.go",
        "keyservice.go",
        "server.go",
        "session.go",
    ],
    importpath = "upspin.io/rpc",
    visibility = ["//visibility:public"],
    deps = [
        "//bind",
        "//cache",
        "//errors",
